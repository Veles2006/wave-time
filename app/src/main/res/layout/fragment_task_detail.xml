<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingTop="50dp"
        android:background="@color/primary_blue_light"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:background="@android:color/transparent"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_left_solid_full"
            app:tint="@color/white"
            android:contentDescription="@string/back_task_list" />
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/task_detail"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="0dp"/>

        <ImageButton
            android:id="@+id/btnEdit"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:layout_marginEnd="8dp"
            android:background="@android:color/transparent"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_pen_solid_full"
            app:tint="@color/white"
            android:contentDescription="@string/edit_task" />

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:layout_marginEnd="8dp"
            android:background="@android:color/transparent"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_trash_solid_full"
            app:tint="@color/white"
            android:contentDescription="@string/delete_task" />
        
        <ImageButton
            android:id="@+id/btnSuccess"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_check_solid_full"
            app:tint="@color/white"
            android:background="@android:color/transparent"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            android:contentDescription="@string/btn_task_created_successfully" />
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_header"
        app:layout_constraintVertical_bias="0.0">

        <TextView
            android:id="@+id/tvTaskName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="24dp"
            android:text="Task Name"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivDescriptionIcon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="14dp"
            android:layout_marginTop="18dp"
            android:padding="4dp"
            android:src="@drawable/ic_circle_solid_full"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTaskName" />

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="Description"
            android:textColor="@color/black"
            android:textSize="14sp"
            app:layout_constraintStart_toEndOf="@id/ivDescriptionIcon"
            app:layout_constraintTop_toBottomOf="@id/tvTaskName" />

        <ImageView
            android:id="@+id/ivStatusIcon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="14dp"
            android:layout_marginTop="18dp"
            android:padding="4dp"
            android:src="@drawable/ic_circle_solid_full"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvDescription" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="Status"
            android:textColor="@color/black"
            android:textSize="14sp"
            app:layout_constraintStart_toEndOf="@id/ivStatusIcon"
            app:layout_constraintTop_toBottomOf="@id/tvDescription" />

        <ImageView
            android:id="@+id/ivDateIcon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="14dp"
            android:layout_marginTop="18dp"
            android:src="@drawable/ic_calendar_solid_full"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvStatus" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="Date"
            android:textColor="@color/black"
            android:textSize="14sp"
            app:layout_constraintStart_toEndOf="@id/ivDateIcon"
            app:layout_constraintTop_toBottomOf="@id/tvStatus" />

        <ImageView
            android:id="@+id/ivDifficultyIcon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="14dp"
            android:layout_marginTop="18dp"
            android:src="@drawable/ic_star_solid_full"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvDate" />

        <TextView
            android:id="@+id/tvDifficulty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="Difficulty"
            android:textColor="@color/black"
            android:textSize="14sp"
            app:layout_constraintStart_toEndOf="@id/ivDifficultyIcon"
            app:layout_constraintTop_toBottomOf="@id/tvDate" />

        <ImageView
            android:id="@+id/ivRewardIcon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="14dp"
            android:layout_marginTop="18dp"
            android:src="@drawable/ic_gift_solid_full"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvDifficulty" />

        <TextView
            android:id="@+id/tvReward"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="Reward"
            android:textColor="@color/black"
            android:textSize="14sp"
            app:layout_constraintStart_toEndOf="@id/ivRewardIcon"
            app:layout_constraintTop_toBottomOf="@id/tvDifficulty" />

        <ImageView
            android:id="@+id/ivPenaltyIcon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:padding="4dp"
            android:layout_marginStart="14dp"
            android:layout_marginTop="18dp"
            android:src="@drawable/ic_circle_solid_full"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvReward" />

        <TextView
            android:id="@+id/tvPenalty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="Penalty"
            android:textColor="@color/black"
            android:textSize="14sp"
            app:layout_constraintStart_toEndOf="@id/ivPenaltyIcon"
            app:layout_constraintTop_toBottomOf="@id/tvReward" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>